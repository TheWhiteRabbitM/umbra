{
  "name": "umbra",
  "version": "0.1.0",
  "private": true,
  "description": "Umbra — non-custodial messaging + wallet on Polkadot, with a Revive/PolkaVM smart-contract network and encrypted payloads on the Bulletin Chain.",
  "workspaces": [
    "contracts",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "contracts:build": "npm run build --workspace contracts",
    "contracts:deploy": "npm run deploy --workspace contracts",
    "shots": "node scripts/shots.mjs",
    "lint": "npm run lint --workspace frontend"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright-core": "^1.60.0"
  }
}
